# Copy to .env and fill in values.
# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# JWT secret: openssl rand -hex 32

APP_SECRET_KEY=
CRYPTO_KEY=
# 로컬 기본. Render 등 PaaS에서 SQLite 파일만 쓰면 재배포·스핀다운 후 데이터가 사라질 수 있음 → README «프로덕션 SQLite».
DATABASE_URL=sqlite:///./data.db

# eTL 스크래핑: false 로 두면 동기화 시 Chrome 창이 보입니다(로그인 차단·디버깅용).
# 웹 UI의 「🔐 eTL 로그인」(/api/sync/etl/prepare)는 비헤드리스로만 동작합니다. ETL_HEADLESS=true 이면 해당 API는 오류를 반환합니다.
ETL_HEADLESS=true
# 창이 보일 때만 적용: 동기화가 끝난 뒤 브라우저를 닫기 전 대기(초). 0 이면 즉시 종료.
ETL_HEADED_PAUSE_SEC=8
# ETL_HEADLESS=false(창이 보임)이면 동기화 후에도 브라우저를 기본으로 닫지 않습니다. headless=true 인데 창을 남기려면 true.
ETL_KEEP_BROWSER_OPEN=false
# Selenium 브라우저: chrome | edge | firefox | safari | system (mac→Safari, Windows→Edge, 그 외 Chrome)
ETL_BROWSER=chrome
# Chrome을 먼저 원격 디버깅으로 띄우면(예: Mac)
#   /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --remote-debugging-port=9222
# ETL_HEADLESS=false 이고 ETL_BROWSER=chrome 일 때 Selenium이 아래 주소의 기존 Chrome에 붙습니다.
ETL_CHROME_DEBUGGER_ADDRESS=127.0.0.1:9222

# --- Google OAuth (Web application client in Cloud Console) ---
# 콜백 경로는 고정: GET /api/oauth/google/callback (app/routers/google_oauth.py)
#
# [검증 체크리스트 — 값이 하나라도 다르면 OAuth가 깨집니다]
# 1) Google Cloud Console → OAuth 클라이언트 → «승인된 리디렉션 URI»
# 2) 서버에 올린 OAuth 클라이언트 JSON(web) 안의 "redirect_uris" 배열
# 3) 아래 GOOGLE_REDIRECT_URI
# 세 곳 문자열이 완전히 같아야 합니다(대소문자·www 유무·끝 슬래시까지).
#
# 프로덕션 GOOGLE_REDIRECT_URI는 브라우저 주소와 동일하게:
#   - https:// 만 (프로덕션에서 http 콜백 없음)
#   - www 유무는 실제 도메인과 동일
#   - 경로는 정확히 /api/oauth/google/callback (끝 트레일링 슬래시 없음)
# 프로덕션(Render): 대시보드 Public URL의 호스트를 <실제호스트>에 넣어 한 줄로 맞춤(끝 슬래시 없음).
#   GOOGLE_REDIRECT_URI=https://<실제호스트>/api/oauth/google/callback
#
# 환경별: 프로덕션 .env에는 프로덕션 URI 한 값만, 로컬 .env에는 로컬 URI 한 값만.
# 로컬+프로덕션 둘 다 쓰면: Console·JSON redirect_uris에는 여러 URI 등록,
# 각 서버 환경의 GOOGLE_REDIRECT_URI는 그중 해당 환경 하나만.
# (credentials.json 은 환경마다 별도 복사본을 두거나, redirect_uris에 여러 줄을 넣습니다.)
#
# [배포 후 스모크] 브라우저에서 한 바퀴:
#   .../api/oauth/google/authorize → Google 동의 → .../api/oauth/google/callback → /?google=connected
#
GOOGLE_CLIENT_SECRETS_FILE=credentials.json
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/oauth/google/callback

# Optional: Stripe later (customer portal / webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
